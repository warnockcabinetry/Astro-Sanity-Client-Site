---
import Layout from "../layouts/Layout.astro";
import { getAllContact } from "../lib/api";
import axios from "axios";
import { urlForImage } from "../lib/urlForImage";
import { Image } from "@unpic/astro";
import FormComponent from "../components/FormComponent";

const size = "0.3rem";
const offWhite = "rgb(255, 255, 255)";
const contact = await getAllContact();
const currentUrl = new URL(Astro.url.origin);

const getBlockText = (blocks = []) => {
  return blocks
    .filter((block) => block?._type === "block" && Array.isArray(block.children))
    .map((block) =>
      block.children
        .map((child) => child?.text || "")
        .join("")
        .trim()
    )
    .filter(Boolean)
    .join("\n");
};

const contactPage = contact?.[0] || {};
const contactSubheadingText = getBlockText(contactPage.subheading);
const belowMarkerRegex = /\[\[\s*below\s*\]\]/i;
const [contactSubheadingAboveRaw, ...contactSubheadingBelowParts] = contactSubheadingText.split(
  belowMarkerRegex
);
const contactSubheadingAbove = contactSubheadingAboveRaw.trim();
const contactSubheadingBelow = contactSubheadingBelowParts.join("\n").trim();
const normalizeText = (value = "") => String(value || "").trim();
const isGenericContactLabel = (value = "") => /^(contact|contact\s+us)$/i.test(normalizeText(value));

const headingCandidates = [
  contactPage.subtitle,
  contactPage?.pageBuilder?.[0]?.subheaders,
  contactPage.title,
].map(normalizeText);

const contactHeadingText =
  headingCandidates.find((value) => value && !isGenericContactLabel(value)) ||
  headingCandidates.find(Boolean) ||
  "REQUEST A QUOTE";
---

<Layout>
  <script is:inline src="https://unpkg.com/axios/dist/axios.min.js"></script>
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>
  <script is:inline async>
    window.addEventListener("DOMContentLoaded", function () {
      const status = document.getElementById("status");
      const statusTop = document.getElementById("status-top");
      let form = document.getElementById("form");

      const setStatus = (message) => {
        if (status) {
          status.innerHTML = message;
        }

        if (statusTop) {
          statusTop.innerHTML = message;
        }
      };

      document.addEventListener("submit", async (event) => {
        event.preventDefault();

        let formData = new FormData(form);
        const formValues = Object.fromEntries(formData.entries(), null, 2);

        const gReCaptchaResponse = grecaptcha.getResponse();
        let userFormValues = {
          firstName: formValues.firstName,
          lastName: formValues.lastName,
          email: formValues.email,
          message: formValues.message,
          category: formValues.category,
        };

        console.log({ formValues });
        console.log({ userFormValues });
        console.log({ gReCaptchaResponse });

        const firstNameInput = document.getElementById("firstName");
        const lastNameInput = document.getElementById("lastName");
        const emailInput = document.getElementById("email");
        const messageInput = document.getElementById("message");
        const categoryInput = document.getElementById("category");

        formData.append("first", firstNameInput.value);
        formData.append("last", lastNameInput.value);
        formData.append("email", emailInput.value);
        formData.append("message", messageInput.value);
        formData.append("category", categoryInput.value);

        axios
          .post("https://submit-form.com/n6nFdqZtI", {
            firstName: formValues.firstName,
            lastName: formValues.lastName,
            email: formValues.email,
            message: formValues.message,
            category: formValues.category,
            "g-recaptcha-response": grecaptcha.getResponse(),
            // headers: {
            //   "Content-Type": "application/json",
            //   Accept: "application/json",
            // },
          })

          .then((response) => {
            if (response.data.status === 200) {
              console.log("200");
              setStatus("Thanks for your email");
              document.getElementById("form").reset();
            } else {
              console.log(response.data);
              console.log("not 200", response.data.status);
              setStatus("Thanks for your email");
              document.getElementById("form").reset();
            }
          })
          .catch((error) => {
            console.log(error.response.data);
            setStatus("Something went wrong. Please try again later.");
             document.getElementById("form").reset();
          });
      });
    });
  </script>

  <!-- client validation -->

  <script
    async
    is:inline
    src="https://rickharrison.github.io/validate.js/validate.min.js"></script>

  <section class="contact-form">
    <Image
      src={urlForImage(contactPage.image).url()}
      class="bckgrnd-contact"
      alt="contact-image"
      layout="fullWidth"
      width={1000}
      height={1000}
      placeholder="blurhash"
      priority
    />

    <h2 class="contact-title">
      {contactHeadingText}
    </h2>

    {
      contactSubheadingAbove && (
        <p class="contact-subheader">{contactSubheadingAbove}</p>
      )
    }

    <p id="status-top" class="form-status form-status-top" aria-live="polite"></p>

    <div class="contact-container">
      <form class="form contact-container" id="form">
        <input
          type="checkbox"
          name="_honeypot"
          style="display:none"
          tabindex="-1"
          autocomplete="off"
        />
        <input
          name="firstName"
          placeholder="first name"
          id="firstName"
          class="text-input"
          autocomplete="on"
          required
          required
          title="Please enter your last name without any numbers"
          pattern="^[^\d]*$"
          minlength="2"
          type="text"
        />
        <input
          type="text"
          name="lastName"
          id="lastName"
          pattern="^[^\d]*$"
          placeholder="last name"
          class="text-input"
          minlength="1"
          required
          required
          title="Please enter your last name without any numbers"
        />

        <input
          type="email"
          name="email"
          id="email"
          placeholder="email"
          class="text-input"
          autocomplete="on"
          pattern="^(?=.{5,}$).*@.*$"
          required
          title="Please am email containing the @ character"
          minlength="4"
        />
        <textarea
          name="message"
          placeholder="message"
          id="message"
          class="text-input message-text"
          required></textarea>
        <div class="selector--container">
          <label for="category" class="cat-selector-label"
            >Select Project Category:</label
          >
          <select name="category" class="custom-select" id="category">
            <option value="Kitchens">Kitchens</option>
            <option value="Cabinetry">Cabinetry</option>
            <option value="Closets">Closets</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div
          class="g-recaptcha"
          data-sitekey="6Ld_D-QpAAAAALCq5dNKAZiMKShQI4PpsIkVGX9_"
        >
        </div>

        <input
          type="submit"
          id="send-button"
          value="Send"
          class="send-button-class"
        />

        <p class="form-response-note">Expect response within 2 business day</p>
      </form>
    </div>

    <div id="previews"></div>

    {
      contactSubheadingBelow && (
        <p class="contact-subheader contact-subheader-below">{contactSubheadingBelow}</p>
      )
    }

    <h3 id="status"></h3>
  </section>
</Layout>

<script
  src="https://cdn.jsdelivr.net/npm/@uploadcare/blocks@0.35.2/web/lr-file-uploader-regular.min.js"
>
  // import * as LR from "https://cdn.jsdelivr.net/npm/@uploadcare/blocks@0.35.2/web/lr-file-uploader-regular.min.js";
  LR.registerBlocks(LR);

  const providerNode = document.getElementById("my-uploader-provider");
  const previewsNode = document.getElementById("previews");

  providerNode.addEventListener("change", handleChangeEvent);
  function handleChangeEvent(e) {
    console.log("change event payload", e);
    renderFiles(e.detail.allEntries.filter((f) => f.status === "success"));
  }

  function renderFiles(files) {
    const renderedFiles = files.map((file) => {
      const fileNode = document.createElement("div");
      fileNode.setAttribute("class", "preview-wrapper");

      const imgNode = document.createElement("img");
      imgNode.setAttribute("src", file.cdnUrl);
      imgNode.setAttribute("class", "preview");
      imgNode.setAttribute("width", "50");
      imgNode.setAttribute("height", "50");
      imgNode.setAttribute("alt", file.fileInfo.originalFilename);
      imgNode.setAttribute("title", file.fileInfo.originalFilename);

      console.log(file.fileInfo);

      // const imgNameNode = document.createElement("p");
      // imgNameNode.setAttribute("class", "preview-data");
      // imgNameNode.textContent = `${file.fileInfo.originalFileName}`;
      // const imgSizeNode = document.createElement("p");
      // imgSizeNode.setAttribute("class", "preview-data");
      // imgSizeNode.textContent = `${file.fileInfo.fileSize}`;
      // fileNode.append(imgNode, imgNameNode, imgSizeNode);

      return fileNode;
    });

    previewsNode.replaceChildren(...renderedFiles);
  }
</script>

<script>
  ScrollReveal({ distance: "50px" });
  ScrollReveal().reveal("#status", {
    delay: 250,
    origin: "bottom",
    easing: "ease-in",
  });
</script>

<style define:vars={{ size, offWhite }} is:global>
  #status {
    color: var(--offWhite);
    padding-top: 0.5rem;
    font-size: 1.4rem;
    margin-top: -2rem;
  }

  .form-status {
    color: var(--offWhite);
    font-size: 1.15rem;
    margin: 0;
    text-align: center;
  }

  .form-status-top {
    min-height: 1.3rem;
    margin-bottom: 0.75rem;
  }

  .g-recaptcha {
    margin: 2rem;
  }
  .contact-form {
    position: relative;
    isolation: isolate;
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    justify-self: center;
    align-items: center;
  }

  .contact-form > * {
    position: relative;
    z-index: 1;
  }

  .contact-container {
    width: 80%;
    background-color: ececec;
    display: flex;
    flex-direction: column;
    justify-self: center;
    align-items: center;
    border-radius: 0;
  }

  .bckgrnd-contact {
    z-index: 0;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    opacity: 0.46;
    pointer-events: none;
  }

  input {
    border: none;
    margin: 0.2rem;
  }

  #previews {
    margin: 2rem;
    object-fit: cover;
  }

  .preview-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .preview-data {
    font-size: 0.8rem;
    display: none;
  }

  .send-button-class {
    position: relative;
    font-size: 2rem;
    text-transform: uppercase;
    width: 10rem;
    text-align: center;
    border-radius: 0;
    padding: 0.5rem;
    border: none;
    background: linear-gradient(38deg, #f05a24, #ba2f2f);
    color: #efefef;
    transition: ease-out 0.4s;
    box-shadow: 2px 2px 2px 4px rgba(35, 35, 35, 0.35);
  }

  .send-button-class:active {
  }

  .send-button-class:hover {
    background: linear-gradient(-35deg, #f05a24, #ba2f2f);
    transition: ease-in 0.5s;
    color: rgb(30, 30, 30);
    box-shadow: 2px 2px 2px 4px rgba(35, 35, 35, 0.35);
  }

  .send-button-class::after {
  }

  .form-response-note {
    color: #e6e6e6;
    font-size: 0.95rem;
    margin: 0.8rem 0 0.4rem;
    text-align: center;
  }

  .selector--container {
    display: flex;
    flex-direction: row;
    justify-content: space-around;
    align-items: center;
    margin: 0.5rem;
    padding: 1rem;
  }

  .contact-subheader {
    padding: 2rem;
    font-size: 1.2rem;
    color: white;
    max-width: 40rem;
    margin-bottom: 1rem;
    white-space: pre-line;
  }

  .contact-subheader-below {
    width: min(100%, 40rem);
    align-self: flex-start;
    text-align: left;
    margin-top: 0.5rem;
    margin-bottom: 0;
    margin-left: max(1rem, 10vw);
    margin-right: auto;
  }

  .contact-title {
    font-family: "Cormorant Garamond", serif;
    font-weight: 700;
    letter-spacing: 0.02em;
    font-size: 3rem;
    color: var(--offWhite);
    padding-top: 2rem;
  }
  @media screen and (max-width: 500px) {
    .contact-title {
      font-size: 2.5rem;
      margin-bottom: -1rem;
    }
  }

  .custom-select {
    min-width: 150px;
    padding: 1rem;
    max-width: 200px;
    margin-left: 1rem;
    position: relative;
    border-radius: 0;
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #caced1;
  }

  #my-uploader-provider {
    background-color: #d6d6d6;
    color: black;
  }

  .uploadcare--widget__button {
    margin-top: 0.4rem;
    color: black;
    background-color: var(--offWhite);
  }

  .custom-select::before,
  .custom-select::after {
    --size: 0.3rem;
    position: absolute;
    content: "";
    right: 1rem;
    pointer-events: none;
  }

  .custom-select::before {
    border-left: var(--size) solid transparent;
    border-right: var(--size) solid transparent;
    border-bottom: var(--size) solid black;
    top: 40%;
  }

  .custom-select::after {
    border-left: var(--size) solid transparent;
    border-right: var(--size) solid transparent;
    border-top: var(--size) solid black;
    top: 55%;
  }

  label {
    display: inline;
    color: var(--offWhite);
  }

  select {
    appearance: none;
    /* safari */
    -webkit-appearance: none;
    /* other styles for aesthetics */
    width: 100%;
    font-size: 1.15rem;
    padding: 0.675em 6em 0.675em 1em;
    background-color: #ffffff;
    border: 1px solid #caced1;
    border-radius: 0;
    color: #000000;
    cursor: pointer;
  }

  .message-text {
    overflow: auto;
    white-space: normal;
    text-overflow: "-";
    height: 10rem;
  }

  .text-input {
    color: #000000;
    background-color: #ffffff;
    border: 1px solid #caced1;
    width: 80%;
    padding: 1rem;
    border-radius: 0;
    margin-bottom: 1rem;
  }

  .text-input::placeholder {
    color: rgba(0, 0, 0, 0.55);
  }

  /* input:invalid {
    box-shadow: 0 0 5px 1px rgb(245, 9, 9);
  }

  input:focus:invalid {
    box-shadow: none;
  } */

  @media screen and (max-width: 700px) {
    .contact-form {
      width: 100%;
      overflow-x: hidden;
    }

    .contact-container {
      width: min(92vw, 40rem);
    }

    .bckgrnd-contact {
      object-position: center 30%;
    }

    .text-input {
      min-width: 0;
      width: 100%;
    }

    .selector--container {
      flex-direction: column;
      width: 100%;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    .cat-selector-label {
      margin-bottom: 0.5rem;
    }
    .custom-select {
      margin: 0;
      width: 100%;
      max-width: none;
    }
  }

  .box-input {
    height: 20rem;
    border: 1px dashed black;
  }

  .checkbox {
  }

  .box__dragndrop,
  .box__uploading,
  .box__success,
  .box__error {
    display: none;
  }

  .box.has-advanced-upload {
    background-color: var(--offWhite);
    outline: 2px dashed black;
    outline-offset: -10px;
  }

  .box.has-advanced-upload .box__dragndrop {
    display: inline;
  }

  .my-config {
    --darkmode: 0;
    --h-accent: 144;
    --s-accent: 67%;
    --l-accent: 57%;
  }
</style>
