---
import Image from "astro/components/Image.astro";
import headerLogo from "../images/header-logo.svg";
import Logo from "../components/Logo.astro";
const accentColor = "#f05a24";
interface Props {
  navTitle?: string;
}

const siteTitle = "Warnock Cabinetry";
---

<header>
  <nav role="navigation" aria-label="Main menu" class="heading-menu-nav">
    <span id="nav-label" hidden>Navigation</span>
    <a class="mobile-brand-bar" href="/" data-astro-prefetch aria-label="Go to home page">
      <span class="mobile-brand-name">{siteTitle}</span>
    </a>
    <button
      id="menuToggle"
      aria-expanded="false"
      class="hamburger-menu"
      aria-controls="mobile-main-menu"
      aria-label="Open menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <ul id="mobile-main-menu" class="heading-menu">
      <li class="header-logo-item">
        <a class="header-home-link" href="/" data-astro-prefetch aria-label="Go to home page">
          <Logo class="header-logo" />
        </a>
      </li>
      <li class="site-title" aria-label="Business title">
        <a class="site-title-link" href="/" data-astro-prefetch>{siteTitle}</a>
      </li>
      <li><a class="header-menu-item" href="/" data-astro-prefetch>Home</a></li>
      <li class="projects-menu">
        <button
          type="button"
          class="header-menu-item projects-trigger"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Projects
        </button>
        <ul class="projects-dropdown" aria-label="Project categories">
          <li>
            <a class="projects-dropdown-link" href="/projects/kitchens/" data-astro-prefetch
              >Kitchens</a
            >
          </li>
          <li>
            <a class="projects-dropdown-link" href="/projects/wardrobes/" data-astro-prefetch
              >Wardrobes</a
            >
          </li>
          <li>
            <a class="projects-dropdown-link" href="/projects/built-ins/" data-astro-prefetch
              >Built-Ins</a
            >
          </li>
        </ul>
      </li>
      <li>
        <a class="header-menu-item" href="/contact/" data-astro-prefetch
          >Contact</a
        >
      </li>
      <li>
        <a class="header-menu-item about-nav-link" href="/about/" data-astro-prefetch>About</a>
      </li>
    </ul>
  </nav>
  
</header>

<style>
  .hamburger-menu {
    display: none;
  }

  header {
    padding: 0;
  }

  li {
    list-style: none;
  }

  .heading-menu-nav {
  }

  .mobile-brand-bar {
    display: none;
  }

  .heading-menu {
    display: flex;
    text-decoration: none;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: 1.5rem;
    height: 6rem;
    padding: 0 2rem;
    margin-top: -0.5rem;
    width: 100%;
    background-color: #000000;
    color: #ffffff;
    position: absolute;
    z-index: 10;
  }

  .header-logo {
    justify-self: flex-start;
    margin-left: 0;
    height: 4rem;
    fill: #f06124;
  }

  .site-title,
  .mobile-brand-name {
    color: #ffffff;
    font-family: "Bodoni Moda", "Cormorant Garamond", serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-right: auto;
    white-space: nowrap;
  }

  .site-title-link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    color: inherit;
  }

  .header-home-link {
    display: inline-flex;
    align-items: center;
    height: 100%;
  }

  .header-logo-item {
    display: inline-flex;
    align-items: center;
    height: 100%;
  }

  .header-menu-item {
    font-family: "Cormorant Garamond", serif;
    text-decoration: none;
    list-style: none !important;
    color: #ffffff;
    font-size: 1.3rem;
  }

  .about-nav-link {
    font-family: "Cormorant Garamond", serif !important;
  }

  .projects-menu {
    position: relative;
    padding-bottom: 0;
    display: flex;
    align-items: center;
    height: 100%;
  }

  .projects-trigger {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    line-height: 1;
    gap: 0.45rem;
    background: transparent;
    border: 0;
    color: #ffffff;
    font: inherit;
    padding: 0;
  }

  .projects-trigger::after {
    content: "";
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    border-right: 1.5px solid #ffffff;
    border-bottom: 1.5px solid #ffffff;
    transform: translateY(-0.08rem) rotate(45deg);
    transition: transform 0.2s ease;
  }

  .projects-dropdown {
    position: absolute;
    top: calc(50% + 0.95rem);
    left: 0;
    min-width: 11rem;
    padding: 0.6rem 0.85rem;
    margin: 0;
    background: #000000;
    border: none;
    display: none;
    z-index: 20;
  }

  .projects-menu::after {
    content: "";
    position: absolute;
    left: 0;
    top: calc(50% + 0.75rem);
    width: 100%;
    height: 0.5rem;
  }

  .projects-dropdown-link {
    display: block;
    color: #ffffff;
    text-decoration: none;
    font-size: 1.1rem;
    line-height: 1.8;
    white-space: nowrap;
  }

  .projects-dropdown-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  .projects-menu:hover .projects-dropdown,
  .projects-menu:focus-within .projects-dropdown {
    display: block;
  }

  @media screen and (min-width: 701px) {
    .heading-menu > * {
      display: flex;
      align-items: center;
      height: 100%;
    }

    .site-title-link {
      line-height: 1;
    }

    .header-menu-item {
      display: inline-flex;
      align-items: center;
      line-height: 1;
    }
  }

  @media screen and (max-width: 700px) {
    .mobile-brand-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 3.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000000;
      color: #ffffff;
      text-decoration: none;
      padding-right: 0;
      z-index: 95;
    }

    .mobile-brand-name {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      text-align: center;
      white-space: nowrap;
    }

    .heading-menu > li {
      margin: 0;
      padding: 0;
    }

    .header-logo {
      display: none;
    }

    .header-logo-item {
      height: auto;
    }

    .header-home-link {
      height: auto;
    }

    .site-title {
      color: white;
      font-size: 1.1rem;
      line-height: 1.2;
      margin-right: 0;
      white-space: normal;
      text-align: center;
      display: none;
    }

    .heading-menu {
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 0.9rem;
      padding: 4.2rem 1rem 1.5rem;
      transition: 0.4s ease-in;
      translate: -100vw;
      transition: translate 0.5s ease-in-out;
      z-index: 90;
      overflow-y: auto;
    }
    #menuToggle[aria-expanded="true"] {
      + .heading-menu {
        translate: 0;
      }
    }

    .hamburger-menu {
      border-radius: 0;
      border: none;
      padding: 0;
      background: #000000;
      z-index: 120;
      height: 2.9rem;
      width: 2.9rem;
      display: flex;
      flex-flow: column;
      justify-content: center;
      align-items: center;
      gap: 0.36rem;
      position: fixed;
      top: 1.75rem;
      transform: translateY(-50%);
      right: 20px;
      cursor: pointer;
    }

    .hamburger-line {
      display: block;
      width: 1.35rem;
      height: 2px;
      background: #ffffff;
      transform-origin: center;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    #menuToggle[aria-expanded="true"] .hamburger-line:first-child {
      transform: translateY(0.28rem) rotate(45deg);
    }

    #menuToggle[aria-expanded="true"] .hamburger-line:last-child {
      transform: translateY(-0.28rem) rotate(-45deg);
    }

    @media screen and (max-width: 500px) {
      .hamburger-menu {
        height: 2.6rem;
        width: 2.6rem;
      }
    }

    .header-menu-item {
      color: #ffffff;
      font-size: 1.45rem;
      line-height: 1.2;
      padding: 0.3rem 0.5rem;
    }

    .projects-menu {
      position: static;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
      height: auto;
    }

    .projects-dropdown {
      position: static;
      display: none;
      flex-direction: column;
      align-items: center;
      gap: 0.45rem;
      padding: 0;
      min-width: 0;
      border: none;
      background: transparent;
      margin-top: 0.2rem;
    }

    .projects-menu.is-open .projects-dropdown {
      display: flex;
    }

    .projects-menu.is-open .projects-trigger::after {
      transform: translateY(0.05rem) rotate(225deg);
    }

    .projects-dropdown-link {
      font-size: 1.12rem;
      line-height: 1.35;
      padding: 0.32rem 0.45rem;
    }
  }
</style>

<script is:inline>
  function setupMobileMenu() {
    const menuToggle = document.querySelector("#menuToggle");
    const menuLinks = document.querySelectorAll(".heading-menu a");
    const projectsMenu = document.querySelector(".projects-menu");
    const projectsTrigger = document.querySelector(".projects-trigger");

    if (!menuToggle) {
      return;
    }

    if (menuToggle.dataset.menuBound === "true") {
      document.body.classList.remove("mobile-menu-open");
      menuToggle.setAttribute("aria-expanded", "false");
      menuToggle.setAttribute("aria-label", "Open menu");
      return;
    }

    const setMenuState = (expanded) => {
      menuToggle.setAttribute("aria-expanded", String(expanded));
      menuToggle.setAttribute("aria-label", expanded ? "Close menu" : "Open menu");
      document.body.classList.toggle("mobile-menu-open", expanded);

      if (!expanded && projectsMenu && projectsTrigger) {
        projectsMenu.classList.remove("is-open");
        projectsTrigger.setAttribute("aria-expanded", "false");
      }
    };

    const setProjectsState = (expanded) => {
      if (!projectsMenu || !projectsTrigger) {
        return;
      }

      projectsMenu.classList.toggle("is-open", expanded);
      projectsTrigger.setAttribute("aria-expanded", String(expanded));
    };

    menuToggle.addEventListener("click", () => {
      const isExpanded = menuToggle.getAttribute("aria-expanded") === "true";
      setMenuState(!isExpanded);
    });

    menuLinks.forEach((link) => {
      link.addEventListener("click", () => {
        setMenuState(false);
      });
    });

    if (projectsTrigger) {
      projectsTrigger.addEventListener("click", () => {
        const isOpen = projectsTrigger.getAttribute("aria-expanded") === "true";
        setProjectsState(!isOpen);
      });
    }

    window.addEventListener("resize", () => {
      if (window.innerWidth > 700) {
        setMenuState(false);
      }
    });

    window.addEventListener("pagehide", () => {
      setMenuState(false);
    });

    menuToggle.dataset.menuBound = "true";

    setMenuState(false);
    setProjectsState(false);
  }

  setupMobileMenu();
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>

<style is:global>
  body.mobile-menu-open {
    overflow: hidden;
  }
</style>

<script
  type="module"
  src="https://unpkg.com/scrollreveal@4.0.9/dist/scrollreveal.min.js"
>
  ScrollReveal().reveal(".header-menu-item", {
    duration: 2000,
  });
</script>
